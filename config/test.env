# DO NOT PUT SECRETS HERE — this file is committed.
# Test mode points at a local test database. Override via .env.local or
# the process env if your local DSN differs.

LIVEABOARD_ADDR=:0
LIVEABOARD_DATABASE_URL=postgres://localhost:5432/liveaboard_test?sslmode=disable
LIVEABOARD_COOKIE_SECURE=false

# bcrypt cost 4 keeps the suite fast; never use this in production.
LIVEABOARD_BCRYPT_COST=4

LIVEABOARD_SESSION_DURATION=336h
LIVEABOARD_VERIFICATION_DURATION=24h

VITE_API_BASE=/api
