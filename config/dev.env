# DO NOT PUT SECRETS HERE — this file is committed.
# Secrets live in process env (or .env.local for dev/test convenience).
# See docs/CONFIG.md for the full list of keys.

LIVEABOARD_ADDR=:8080
LIVEABOARD_DATABASE_URL=postgres://localhost:5432/liveaboard?sslmode=disable
LIVEABOARD_COOKIE_SECURE=false
LIVEABOARD_BCRYPT_COST=12
LIVEABOARD_SESSION_DURATION=336h
LIVEABOARD_VERIFICATION_DURATION=24h

# Frontend (consumed by Vite via web/.env.local generated at build time)
VITE_API_BASE=/api
