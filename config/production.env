# DO NOT PUT SECRETS HERE — this file is committed.
# Production secrets must come from the process environment. The loader
# refuses to start if a required secret is sourced from a file in production
# mode. See docs/CONFIG.md.

LIVEABOARD_ADDR=:8080
LIVEABOARD_COOKIE_SECURE=true
LIVEABOARD_BCRYPT_COST=12
LIVEABOARD_SESSION_DURATION=336h
LIVEABOARD_VERIFICATION_DURATION=24h

# Brevo non-secret defaults; override per environment if you switch relay.
LIVEABOARD_SMTP_HOST=smtp-relay.brevo.com
LIVEABOARD_SMTP_PORT=587

# Frontend default; usually fine since the production binary serves the
# SPA on the same origin.
VITE_API_BASE=/api

# Required, env-only:
#   LIVEABOARD_DATABASE_URL=postgres://user:password@host:5432/db
#   LIVEABOARD_APP_BASE_URL=https://app.example.com
#   LIVEABOARD_SMTP_USERNAME=...
#   LIVEABOARD_SMTP_PASSWORD=...
#   LIVEABOARD_SMTP_FROM=Liveaboard <noreply@example.com>
