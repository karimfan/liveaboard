# Liveaboard environment overrides
#
# This file documents every supported environment variable. Copy to
# `.env.local` for personal dev overrides; never commit `.env.local`.
# Production never reads any dotfile — these values must come from the
# process environment in production.

# Mode selection. dev | test | production. Defaults to dev.
LIVEABOARD_MODE=dev

# Listen address. Default in mode files.
LIVEABOARD_ADDR=:8080

# Postgres DSN. SECRET — never commit a real value.
LIVEABOARD_DATABASE_URL=postgres://user:password@host:5432/db

# Set the Secure flag on the session cookie. Required true in production.
LIVEABOARD_COOKIE_SECURE=false

# bcrypt cost. Range [4, 31]. Production should be 12+.
LIVEABOARD_BCRYPT_COST=12

# Session and verification token lifetimes (Go duration syntax).
LIVEABOARD_SESSION_DURATION=336h
LIVEABOARD_VERIFICATION_DURATION=24h

# Frontend base URL for the API. Same-origin "/api" works in dev (via
# the Vite proxy) and in production (binary serves SPA + /api on one port).
VITE_API_BASE=/api
