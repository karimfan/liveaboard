<!doctype html>
<html lang="en">
<body style="font-family: -apple-system, system-ui, 'Segoe UI', Roboto, sans-serif; color: #1c1917; background: #f8f7f6; padding: 24px;">
  <table role="presentation" style="max-width: 480px; margin: 0 auto; background: white; border: 1px solid #e3e0dd; border-radius: 12px; padding: 32px;">
    <tr><td>
      <h1 style="font-family: 'General Sans', sans-serif; font-weight: 700; margin: 0 0 16px;">You've been removed from a trip.</h1>
      <p style="margin: 0 0 16px;">Hi {{.RecipientName}},</p>
      <p style="margin: 0 0 16px;"><strong>{{.InviterName}}</strong> removed you from the trip below.</p>
      <table role="presentation" style="margin: 16px 0; border-collapse: collapse; font-size: 14px;">
        <tr>
          <td style="padding: 4px 12px 4px 0; color: #57534e;">Boat</td>
          <td style="padding: 4px 0;"><strong>{{.TripBoatName}}</strong></td>
        </tr>
        <tr>
          <td style="padding: 4px 12px 4px 0; color: #57534e;">Itinerary</td>
          <td style="padding: 4px 0;">{{.TripItinerary}}</td>
        </tr>
        <tr>
          <td style="padding: 4px 12px 4px 0; color: #57534e;">Dates</td>
          <td style="padding: 4px 0;">{{fmtdate .TripStartDate}} → {{fmtdate .TripEndDate}}</td>
        </tr>
      </table>
      <p style="font-size: 12px; color: #78716c;">If this was a mistake, reach out to {{.InviterName}} or your organization admin to be re-assigned.</p>
    </td></tr>
  </table>
</body>
</html>
