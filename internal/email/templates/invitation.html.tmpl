<!doctype html>
<html lang="en">
<body style="font-family: -apple-system, system-ui, 'Segoe UI', Roboto, sans-serif; color: #1c1917; background: #f8f7f6; padding: 24px;">
  <table role="presentation" style="max-width: 480px; margin: 0 auto; background: white; border: 1px solid #e3e0dd; border-radius: 12px; padding: 32px;">
    <tr><td>
      <h1 style="font-family: 'General Sans', sans-serif; font-weight: 700; margin: 0 0 16px;">Hi {{.RecipientName}}.</h1>
      <p style="margin: 0 0 16px;"><strong>{{.InviterName}}</strong> invited you to join <strong>{{.OrganizationName}}</strong> on {{.AppName}} as a <strong>Cruise Director</strong>.</p>
      <p style="margin: 24px 0;">
        <a href="{{.ActionURL}}" style="display: inline-block; background: #e5853b; color: white; text-decoration: none; padding: 12px 20px; border-radius: 8px; font-weight: 600;">Accept invitation</a>
      </p>
      <p style="font-size: 14px; color: #57534e; margin: 0 0 8px;">Or paste this URL into your browser:</p>
      <p style="font-size: 12px; color: #57534e; word-break: break-all; margin: 0 0 24px;"><a href="{{.ActionURL}}" style="color: #57534e;">{{.ActionURL}}</a></p>
      <p style="font-size: 12px; color: #78716c;">Invitation expires on {{fmtdate .ExpiresAt}}.</p>
    </td></tr>
  </table>
</body>
</html>
