#!/usr/bin/env bash
# Copy to env.sh (gitignored) and fill in your values. Sourced by
# deploy/lib/common.sh; consumed by every script under deploy/.
#
# Variable names match what the application + gcloud expect, so this
# file can also be sourced in a local shell for ad-hoc commands.

# --- GCP project ---
export GCP_PROJECT=your-gcp-project-id
export GCP_REGION=us-central1
export GCP_ZONE=us-central1-a

# --- SMTP (Brevo or any other 587/465 relay) ---
# Names match the keys read by internal/config/config.go. The deploy
# scripts ship these to the VM where systemd loads them as the process
# env for liveaboard.service. Sender domain (LIVEABOARD_SMTP_FROM) must
# be verified at the relay.
export LIVEABOARD_SMTP_HOST=smtp-relay.brevo.com
export LIVEABOARD_SMTP_PORT=587
export LIVEABOARD_SMTP_USERNAME=your-smtp-login
export LIVEABOARD_SMTP_PASSWORD=your-smtp-key
export LIVEABOARD_SMTP_FROM=noreply@your-domain.example
